.env
*.pyc
__pycache__/
.venv/
node_modules/
data/logs/*
data/journal/*
data/briefs/*
data/cache/*
data/memory/paper/*
data/memory/live/*
data/memory/shared/*
!data/**/.gitkeep
*.egg-info/
dist/
build/
.DS_Store
*.swp
*.swo

# graphify build artifacts
graphify-out/cache/
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/.graphify_python

# Backup snapshots and retired files (local working snapshots; never committed).
# Operators take .bak / .retired copies of scripts before risky edits — those
# stay on disk for rollback but should never enter git history.
*.bak
*.bak.*
*.retired
*.retired.*

# Auto-heal historical state (predates the Sentinel cutover on 2026-05-03;
# kept on disk for forensics, not for the repo).
v2/shared-data/scripts/auto_heal_data/dismissed_*/
v2/shared-data/scripts/auto_heal_data/fix_history/

# Runtime lock + scheduling state (ephemeral, machine-local).
.claude/scheduled_tasks.lock
/tmp/quantai-heartbeats/

# Credentials — NEVER commit. The repo had a Google Cloud service-account
# JSON leaked at commit 19e8eea (2026-03-31); the key was rotated on
# 2026-05-06 and the file was scrubbed from history via git filter-repo
# in the same operator action. These patterns are belt-and-suspenders
# against any future reintroduction (and against new key types).
google_service_account*.json
*service_account*.json
*credentials*.json
