# ============================================
# Claude Auto-Trader — Environment Configuration
# ============================================
# NEVER commit this file. It's in .gitignore.
# Copy to .env and fill in your values.

# --- Discord ---
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_server_id

# Channel IDs (create these channels in your Discord server)
CHANNEL_COMMAND=channel_id_here
CHANNEL_CHAT=channel_id_here
CHANNEL_RESEARCH=channel_id_here
CHANNEL_TRADE_PROPOSALS=channel_id_here
CHANNEL_GUARD_LOG=channel_id_here
CHANNEL_EXECUTION_LOG=channel_id_here
CHANNEL_SYSTEM_HEALTH=channel_id_here
CHANNEL_PR_UPDATES=channel_id_here

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-your_key_here
CLAUDE_SONNET_MODEL=claude-sonnet-4-20250514
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# --- Alpaca (Paper Trading — Phase 1) ---
ALPACA_API_KEY=your_paper_api_key
ALPACA_SECRET_KEY=your_paper_secret_key
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Alpaca (Live Trading — Phase 3 ONLY) ---
# ALPACA_LIVE_API_KEY=your_live_api_key
# ALPACA_LIVE_SECRET_KEY=your_live_secret_key
# ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# --- Data Sources ---
ALPHA_VANTAGE_API_KEY=your_av_key_here

# --- System ---
TZ=America/New_York
LOG_LEVEL=INFO
TRADING_MODE=paper
# Options: paper | live | backtest
# Changing to live requires ALPACA_LIVE_* keys above

# --- Token Optimization ---
MAX_CONTEXT_TOKENS=8000
CACHE_TTL_MINUTES=15
BRIEF_MAX_SYMBOLS=10
