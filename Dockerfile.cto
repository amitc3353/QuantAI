# ─────────────────────────────────────────────────────────────
# CTO Listener Container
# Replaces scripts/cto_listener.sh (host-side bash script)
# Watches cto_queue.json → runs Claude Code → posts to Discord
# ─────────────────────────────────────────────────────────────

FROM python:3.12-slim

# Install Node.js 20 (for Claude Code CLI) + git
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Python deps (just requests for Discord webhooks)
RUN pip install --no-cache-dir requests

# Mark project dir as safe for git
RUN git config --global --add safe.directory /app/project

WORKDIR /app

COPY scripts/cto_listener.py /app/cto_listener.py

CMD ["python", "-u", "cto_listener.py"]
